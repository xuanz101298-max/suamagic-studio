rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: userId
    // Fields:
    //   - role: string (required, 'admin' or 'user')
    //
    // Collection: works
    // Document ID: auto-generated
    // Fields:
    //   - title: string (required)
    //   - description: string (required)
    //   - mediaUrl: string (required)
    //   - mediaType: string (required, 'image' or 'video')
    //   - createdAt: timestamp (required)
    //   - order: number (required)
    //
    // Collection: artists
    // Document ID: auto-generated
    // Fields:
    //   - name: string (required)
    //   - description: string (required)
    //   - avatarUrl: string (required)
    //   - createdAt: timestamp (required)
    //   - order: number (required)
    //
    // Collection: settings
    // Document ID: 'global'
    // Fields:
    //   - logoUrl: string (required)
    //
    // Collection: about
    // Document ID: auto-generated
    // Fields:
    //   - title: string (required)
    //   - description: string (required)
    //   - descriptionEn: string (required)
    //   - order: number (required)
    //
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (
          (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
           get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin') ||
          (request.auth.token.email == "xuanz101298@gmail.com")
        );
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Validation functions
    function isValidWork(data) {
      return data.keys().hasAll(['title', 'description', 'mediaUrl', 'mediaType']) &&
             (!('id' in data) || data.id is string) &&
             data.title is string && data.title.size() <= 200 &&
             data.description is string && data.description.size() <= 2000 &&
             data.mediaUrl is string && data.mediaUrl.size() <= 1000 &&
             data.mediaType in ['image', 'video'] &&
             (!('createdAt' in data) || data.createdAt is string || data.createdAt is timestamp) &&
             (!('order' in data) || data.order is number || data.order is string);
    }

    function isValidArtist(data) {
      return data.keys().hasAll(['name', 'description', 'avatarUrl']) &&
             (!('id' in data) || data.id is string) &&
             data.name is string && data.name.size() <= 100 &&
             data.description is string && data.description.size() <= 2000 &&
             data.avatarUrl is string && data.avatarUrl.size() <= 1000 &&
             (!('createdAt' in data) || data.createdAt is string || data.createdAt is timestamp) &&
             (!('order' in data) || data.order is number || data.order is string);
    }

    function isValidSettings(data) {
      return data.keys().hasAll(['logoUrl']) &&
             (data.logoUrl is string || data.logoUrl == null);
    }

    function isValidStudioInfo(data) {
      return data.keys().hasAll(['title', 'description', 'descriptionEn']) &&
             data.title is string && data.title.size() <= 200 &&
             data.description is string && data.description.size() <= 5000 &&
             data.descriptionEn is string && data.descriptionEn.size() <= 5000 &&
             (!('order' in data) || data.order is number || data.order is string);
    }

    function isValidUser(data) {
      return data.keys().hasAll(['role']) &&
             data.role in ['admin', 'user'];
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && isValidUser(request.resource.data) && ((isOwner(userId) && request.resource.data.role == 'user') || isAdmin());
      allow update: if isAuthenticated() && isValidUser(request.resource.data) && ((isOwner(userId) && request.resource.data.role == resource.data.role) || isAdmin());
      allow delete: if isAdmin();
    }

    match /works/{workId} {
      allow read: if true;
      allow create: if isAdmin() && isValidWork(request.resource.data);
      allow update: if isAdmin() && isValidWork(request.resource.data);
      allow delete: if isAdmin();
    }

    match /artists/{artistId} {
      allow read: if true;
      allow create: if isAdmin() && isValidArtist(request.resource.data);
      allow update: if isAdmin() && isValidArtist(request.resource.data);
      allow delete: if isAdmin();
    }

    match /settings/{settingId} {
      allow read: if true;
      allow create: if isAdmin() && isValidSettings(request.resource.data);
      allow update: if isAdmin() && isValidSettings(request.resource.data);
      allow delete: if isAdmin();
    }

    match /about/{infoId} {
      allow read: if true;
      allow create: if isAdmin() && isValidStudioInfo(request.resource.data);
      allow update: if isAdmin() && isValidStudioInfo(request.resource.data);
      allow delete: if isAdmin();
    }
  }
}
